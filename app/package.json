{
  "name": "scenevis-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "dev": "vite --host 127.0.0.1",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.app.json --pretty false",
    "contract:sync": "openapi-typescript openapi.json -o src/shared/api/schema.ts"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@playwright/test": "^1.58.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^27.0.0",
    "openapi-typescript": "^7.10.0",
    "typescript": "^5.9.0",
    "vite": "^8.1.0",
    "vitest": "^4.0.0"
  }
}
