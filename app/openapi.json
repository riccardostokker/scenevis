          "mean",
          "median",
          "minimum",
          "maximum",
          "standard_deviation",
          "robust_sigma",
          "percentile_1",
          "percentile_5",
          "percentile_25",
          "percentile_75",
          "percentile_95",
          "percentile_99",
          "interquartile_range",
          "percentile_5_to_95_range",
          "coefficient_of_variation"
        ],
        "title": "RegionStatistics",
        "type": "object"
      },
      "Regions": {
        "description": "The three regions required for primary visibility analysis.",
        "properties": {
          "bright_background": {
            "$ref": "#/components/schemas/Region"
          },
          "local_background": {
            "$ref": "#/components/schemas/Region"
          },
          "target": {
            "$ref": "#/components/schemas/Region"
          }
        },
        "required": ["target", "local_background", "bright_background"],
        "title": "Regions",
        "type": "object"
      },
      "Result": {
        "description": "Versioned, serializable result for one analyzed scene.",
        "properties": {
          "image": {
            "title": "Image",
            "type": "string"
          },
          "metadata": {
            "$ref": "#/components/schemas/ImageMetadata"
          },
          "metrics": {
            "$ref": "#/components/schemas/Metrics"
          },
          "preview_notice": {
            "default": "Preview brightness has been adjusted. Metrics were calculated from linear source data.",
            "title": "Preview Notice",
            "type": "string"
          },
          "processing": {
            "$ref": "#/components/schemas/Processing"
          },
          "quality": {
            "$ref": "#/components/schemas/QualityAnalysis"
          },
          "region_statistics": {
            "additionalProperties": {
              "$ref": "#/components/schemas/RegionStatistics"
            },
            "title": "Region Statistics",
            "type": "object"
          },
          "scene_id": {
            "title": "Scene Id",
            "type": "string"
          },
          "version": {
            "default": 3,
            "title": "Version",
            "type": "integer"
          },
          "warnings": {
            "items": {
              "type": "string"
            },
            "title": "Warnings",
            "type": "array"
          }
        },
        "required": [
          "scene_id",
          "image",
          "metadata",
          "processing",
          "region_statistics",
          "metrics",
          "quality",
          "warnings"
        ],
        "title": "Result",
        "type": "object"
      },
      "SettingValue": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "integer"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          },
          {
            "items": {
              "type": "integer"
            },
            "type": "array"
          },
          {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ]
      }
    }
  },
  "info": {
    "title": "Scenevis API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/analyses": {
      "post": {
        "description": "Analyze one image with browser-authored regions without persisting either.",
        "operationId": "createAnalysis",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_createAnalysis"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Analysis"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Unprocessable Content"
          }
        },
        "summary": "Create Analysis"
      }
    },
    "/api/health": {
      "get": {
        "description": "Report local service readiness.",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Health"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/api/previews": {
      "post": {
        "description": "Decode one image and return a compressed, display-only preview.",
        "operationId": "createPreview",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_createPreview"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Preview"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Unprocessable Content"
          }
        },
        "summary": "Create Preview"
      }
    }
  }
}
